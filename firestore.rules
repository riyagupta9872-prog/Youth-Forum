rules_version = '2';

// ════════════════════════════════════════════════════════════════════════════
// SAKHI SANG — FIRESTORE SECURITY RULES
// ────────────────────────────────────────────────────────────────────────────
// Mirrors the UI permission model. Three roles + four delegation flags.
//
//   Roles                                Set in: users/{uid}.role
//   ─────────────────────────────────    ────────────────────────
//   superAdmin    — full power           role == 'superAdmin'
//   teamAdmin     — coordinator          role == 'teamAdmin'
//   serviceDevotee — facilitator (read-mostly outside their team)
//                                         role == 'serviceDevotee'
//
//   Delegation flags                     Set in: users/{uid}
//   ─────────────────────────────────    ──────────────────
//   isAttSevaDev          — Live attendance access across all teams
//   canAllTeamCalling     — Submit / edit calling for ANY team
//   canAllTeamReports     — Read reports across ALL teams
//   canManageAllTeams     — Lite super admin: everything except user mgmt /
//                            clear-all / firestore-rules-protected docs
//
// ────────────────────────────────────────────────────────────────────────────
// IMPORTANT: any rule change can lock the app. Keep this file in sync with
// applyRoleUI() in js/ui-core.js.
// ════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──────────────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function self()   { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }

    function isSuperAdmin()       { return isAuth() && self().role == 'superAdmin'; }
    function isCoordinator()      { return isAuth() && self().role == 'teamAdmin'; }
    function isAdminOrCoord()     { return isSuperAdmin() || isCoordinator(); }

    function canManageAllTeams()  { return isAuth() && self().canManageAllTeams == true; }
    function canAllTeamCalling()  { return isAuth() && (self().canAllTeamCalling == true || self().canManageAllTeams == true); }
    function canAllTeamReports()  { return isAuth() && (self().canAllTeamReports == true || self().canManageAllTeams == true); }
    function isAttSeva()          { return isAuth() && self().isAttSevaDev == true; }

    // "Can write data on behalf of any team" — used by attendance / calling /
    // care / event writes that go beyond the writer's own team.
    function canWriteAcrossTeams() { return isSuperAdmin() || canManageAllTeams() || canAllTeamCalling() || isAttSeva(); }

    // ── DEVOTEES ─────────────────────────────────────────────────────────
    // UI gates: Add = super admin + coordinator · Edit = super admin + coordinator · Delete = super admin
    match /devotees/{id} {
      allow read:   if isAuth();
      // Super admin / canManageAllTeams: any team.
      // isAttSeva: can register newcomers from any team during live attendance.
      // isAdminOrCoord: can create devotees scoped to their own team (or null-team).
      allow create: if isSuperAdmin() || canManageAllTeams() || isAttSeva()
        || (isAdminOrCoord() && (
              request.resource.data.get('teamName', null) == self().teamName
           || request.resource.data.get('teamName', null) == null
        ));
      allow update: if isAdminOrCoord() || canManageAllTeams();
      allow delete: if isSuperAdmin() || canManageAllTeams();
    }

    // ── SESSIONS ─────────────────────────────────────────────────────────
    // Created on-demand by DB.getOrCreateSession when any user marks attendance.
    // Restoring / cancelling is admin-only (UI gate: admin-coordinator-only).
    match /sessions/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAdminOrCoord() || canManageAllTeams();
      allow delete: if isSuperAdmin();
    }

    // ── ATTENDANCE ───────────────────────────────────────────────────────
    // Mark attendance for your OWN team by default. Cross-team marking needs a
    // super-admin-granted flag (isAttSevaDev) or full powers (superAdmin /
    // canManageAllTeams). Records carry `teamName` (db.js); a teamless devotee
    // (null team) is always markable so it can't get stranded.
    // Delete only via super admin clear-data flows.
    match /attendanceRecords/{id} {
      allow read:   if isAuth();
      allow create, update: if isAuth() && (
        isSuperAdmin() || canManageAllTeams() || isAttSeva()
        || request.resource.data.get('teamName', null) == self().teamName
        || request.resource.data.get('teamName', null) == null
      );
      allow delete: if isSuperAdmin() || canManageAllTeams();
    }

    // ── CALLING ──────────────────────────────────────────────────────────
    // callingStatus / callingSubmissions are per-week per-devotee writes.
    // INTENT: own-team only for coordinators/facilitators; canAllTeamCalling
    // (or superAdmin / canManageAllTeams) submits any team.
    // NOT YET RULE-ENFORCED: these write payloads do NOT carry `teamName`
    // (see saveCallingStatus in db.js) — adding a team match here would deny
    // every calling write. To enforce, first add `teamName` to those writes,
    // then gate with: canWriteAcrossTeams() || request.resource.data.teamName
    // == self().teamName. Until then, team scoping is UI-only.
    match /callingStatus/{id} {
      allow read:   if isAuth();
      allow create, update: if isAuth();
      allow delete: if isSuperAdmin() || canManageAllTeams();
    }
    match /callingSubmissions/{id} {
      allow read:   if isAuth();
      allow create, update: if isAuth();
      allow delete: if isSuperAdmin() || canManageAllTeams();
    }

    // ── EVENTS ───────────────────────────────────────────────────────────
    // UI gate: admin-coordinator-only (New Event button).
    match /events/{id} {
      allow read:   if isAuth();
      allow write:  if isAdminOrCoord() || canManageAllTeams();
    }
    match /eventDevotees/{id} {
      allow read:   if isAuth();
      allow write:  if isAdminOrCoord() || canManageAllTeams();
    }

    // ── ACTIVITY LOGS (Books / Service / Registration / Donation) ────────
    // UI: all admin-coordinator users can log. Facilitators read-only.
    match /bookDistributions/{id} {
      allow read:   if isAuth();
      allow write:  if isAdminOrCoord() || canManageAllTeams();
    }
    match /services/{id} {
      allow read:   if isAuth();
      allow write:  if isAdminOrCoord() || canManageAllTeams();
    }
    match /registrations/{id} {
      allow read:   if isAuth();
      allow write:  if isAdminOrCoord() || canManageAllTeams();
    }
    match /donations/{id} {
      allow read:   if isAuth();
      allow write:  if isAdminOrCoord() || canManageAllTeams();
    }

    // ── AUDIT TRAILS ─────────────────────────────────────────────────────
    // Append-only for anyone with auth; only super admin can prune.
    match /profileChanges/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update, delete: if isSuperAdmin();
    }
    match /callingStatusChanges/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update, delete: if isSuperAdmin();
    }

    // ── PERSONAL MEETINGS ────────────────────────────────────────────────
    // Senior Prabhuji 1:1 tracking with authority remarks.
    // Read: anyone signed in. Write: super admin OR canManageAllTeams.
    match /personalMeetings/{id} {
      allow read:   if isAuth();
      allow write:  if isSuperAdmin() || canManageAllTeams();
    }

    // ── INTERACTIONS (4-level call/meet tracker) ──────────────────────────
    match /interactions/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == resource.data.byUserId;
      allow delete: if isSuperAdmin();
    }

    // ── SIGN-UP REQUESTS ─────────────────────────────────────────────────
    // Anyone can create a request for their OWN uid (signup flow + self-heal).
    // Only super admin reads the list and decides.
    match /signupRequests/{id} {
      allow read:   if isSuperAdmin();
      allow create: if isAuth() && request.auth.uid == id;
      // The auto-heal path also re-writes the user's own request — allow it.
      allow update: if isSuperAdmin() || (isAuth() && request.auth.uid == id);
      allow delete: if isSuperAdmin();
    }

    // ── USER PROFILES ────────────────────────────────────────────────────
    // read:   anyone signed in (Calling By picker, mentions, etc.)
    // create: super admin (approval flow) OR self-create that does NOT grant the
    //         two catastrophic powers (superAdmin or canManageAllTeams). Lower
    //         roles + narrow delegation flags ARE allowed so the legitimate
    //         self-heal / re-link path keeps working for coordinators and
    //         facilitators (the "stuck on approval, no pending request" fix).
    // update: own uid (edit own profile — but NOT role/team/permission fields)
    //         OR super admin (role, team, permission flags, anything)
    // delete: super admin only
    //
    // ⚠ FIRST SUPER ADMIN: self-create can no longer mint a superAdmin, so the
    //   very first super admin must be created manually in the Firebase console
    //   (Firestore → users → add doc, role:'superAdmin'). After that, all
    //   promotions happen through User Management.
    // ⚠ RESIDUAL RISK: a determined signed-in user could still self-assign
    //   teamAdmin (or a narrow flag) via the SDK. That's far less severe than
    //   superAdmin and is the price of keeping client-side self-heal. For zero
    //   residual risk, move approval/heal to a Cloud Function (admin SDK).
    match /users/{uid} {
      allow read:   if isAuth();
      // Self-create may not grant superAdmin or canManageAllTeams to oneself.
      allow create: if isSuperAdmin()
        || (isAuth() && request.auth.uid == uid
            && request.resource.data.role != 'superAdmin'
            && request.resource.data.get('canManageAllTeams', false) == false);
      // Self-update: only the safe profile fields. Role + team + permissions
      // can only be changed by super admin.
      allow update: if isSuperAdmin()
        || (isAuth() && request.auth.uid == uid
            && request.resource.data.role          == resource.data.role
            && request.resource.data.teamName      == resource.data.teamName
            && (!('isAttSevaDev'      in request.resource.data) || request.resource.data.isAttSevaDev      == resource.data.isAttSevaDev)
            && (!('canAllTeamCalling' in request.resource.data) || request.resource.data.canAllTeamCalling == resource.data.canAllTeamCalling)
            && (!('canAllTeamReports' in request.resource.data) || request.resource.data.canAllTeamReports == resource.data.canAllTeamReports)
            && (!('canManageAllTeams' in request.resource.data) || request.resource.data.canManageAllTeams == resource.data.canManageAllTeams)
            && (!('status'            in request.resource.data) || request.resource.data.status            == resource.data.status));
      allow delete: if isSuperAdmin();
    }

    // ── APP-WIDE SETTINGS ────────────────────────────────────────────────
    // Calling week, etc. Read for everyone signed in; only super admin writes.
    match /settings/{docId} {
      allow read:   if isAuth();
      allow write:  if isSuperAdmin() || canManageAllTeams();
    }

    // ── CALLING WEEK HISTORY ─────────────────────────────────────────────
    match /callingWeekHistory/{id} {
      allow read:   if isAuth();
      allow write:  if isSuperAdmin() || canManageAllTeams();
    }

  }
}
