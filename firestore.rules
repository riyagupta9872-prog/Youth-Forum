rules_version = '2';

// ════════════════════════════════════════════════════════════════════════════
// YOUTH FORUM — FIRESTORE SECURITY RULES
// Authority source: authority.pdf (Tab / SubTab / Authority matrix)
//
//   ROLES                                Set in: users/{uid}.role
//   ─────────────────────────────────    ────────────────────────
//   superAdmin     — full power          role == 'superAdmin'
//   teamAdmin      — coordinator         role == 'teamAdmin'
//   serviceDevotee — facilitator         role == 'serviceDevotee'
//
//   DELEGATION FLAGS                     Set in: users/{uid}
//   ─────────────────────────────────    ──────────────────────
//   isAttSevaDev       — Cross-team ATTENDANCE marking only
//   canAllTeamCalling  — Cross-team calling submit/edit (Team Calling tab)
//   canAllTeamReports  — Cross-team reports read-only
//   canManageAllTeams  — Lite super admin: everything except user-mgmt / clear-all
//
// ════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──────────────────────────────────────────────────────────
    function isAuth()         { return request.auth != null; }
    function self()           { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }

    function isSuperAdmin()   { return isAuth() && self().role == 'superAdmin'; }
    function isCoordinator()  { return isAuth() && self().role == 'teamAdmin'; }
    function isAdminOrCoord() { return isSuperAdmin() || isCoordinator(); }

    function canManageAllTeams() { return isAuth() && self().canManageAllTeams == true; }
    function canAllTeamCalling() { return isAuth() && (self().canAllTeamCalling == true || self().canManageAllTeams == true); }
    function canAllTeamReports() { return isAuth() && (self().canAllTeamReports == true || self().canManageAllTeams == true); }
    function isAttSeva()         { return isAuth() && self().isAttSevaDev == true; }

    // Cross-team CALLING write — does NOT include isAttSeva (that flag is
    // attendance-only; giving it calling write power would be a scope creep).
    function canWriteAcrossTeams() { return isSuperAdmin() || canManageAllTeams() || canAllTeamCalling(); }

    // ── DEVOTEES ─────────────────────────────────────────────────────────
    // Authority:
    //   Add    — any authenticated user (walk-ins during attendance, etc.)
    //            createdBy / profileChanges audit trail stamped in db.js
    //   Edit   — super admin or canManageAllTeams (delegation flag) only
    //   Delete — super admin or canManageAllTeams only
    //   See    — own team only; super admin / cross-team flags see all teams
    //            teamless devotees (null / '') are always readable so a devotee
    //            without a team assigned can't get stranded.
    match /devotees/{id} {
      allow read: if isAuth() && (
        isSuperAdmin() || canManageAllTeams() || canAllTeamReports() || canAllTeamCalling()
        || resource.data.teamName == self().teamName
        || resource.data.teamName == null
        || resource.data.teamName == ''
      );
      allow create: if isAuth();
      allow update: if isSuperAdmin() || canManageAllTeams();
      allow delete: if isSuperAdmin() || canManageAllTeams();
    }

    // ── SESSIONS ─────────────────────────────────────────────────────────
    // Created lazily by any auth user when first marking attendance.
    // Cancel / restore / speaker config = coordinator or higher.
    match /sessions/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAdminOrCoord() || canManageAllTeams();
      allow delete: if isSuperAdmin();
    }

    // ── ATTENDANCE RECORDS ───────────────────────────────────────────────
    // Authority (PDF): Live Attendance → Only Attendance Sewa Devotee
    //   Read: All types of users (Attendance Sheet, Coordinator Performance,
    //         Late Comers, New Comers — all listed as "all users" in PDF).
    //   Write:
    //     • Attendance Sewa Devotee (isAttSeva) — any team (cross-team marking)
    //     • SuperAdmin / canManageAllTeams — any team (corrections + clear-data)
    //   Coordinators and Facilitators without the isAttSeva flag cannot mark
    //   attendance — Live Attendance is exclusively the Att Sewa service.
    match /attendanceRecords/{id} {
      allow read:   if isAuth();
      allow create, update: if isAuth() && (isSuperAdmin() || canManageAllTeams() || isAttSeva());
      allow delete: if isSuperAdmin() || canManageAllTeams();
    }

    // ── CALLING ──────────────────────────────────────────────────────────
    // Authority (PDF) — Team Calling:
    //   Facilitator + Coordinator → own team (read/write/edit)
    //   SuperAdmin                → all teams
    //   Person with special power (canAllTeamCalling) → all teams
    //
    // Submission Reports: all types of users (read)
    // Weekly Reports / Calling History: SuperAdmin all teams,
    //   Coordinator/Facilitator own team (read — enforced at UI, rules open to isAuth)
    match /callingStatus/{id} {
      allow read:   if isAuth();
      allow create, update: if isAuth() && (
        canWriteAcrossTeams()
        || request.resource.data.get('teamName', null) == self().teamName
        || request.resource.data.get('teamName', null) == null
      );
      allow delete: if isSuperAdmin() || canManageAllTeams();
    }
    match /callingSubmissions/{id} {
      allow read:   if isAuth();
      allow create, update: if isAuth() && (
        canWriteAcrossTeams()
        || request.resource.data.get('teamName', null) == self().teamName
        || request.resource.data.get('teamName', null) == null
      );
      allow delete: if isSuperAdmin() || canManageAllTeams();
    }

    // ── EVENTS ───────────────────────────────────────────────────────────
    // Not in authority.pdf explicitly; UI gates with admin-coordinator-only.
    match /events/{id} {
      allow read:  if isAuth();
      allow write: if isAdminOrCoord() || canManageAllTeams();
    }
    match /eventDevotees/{id} {
      allow read:  if isAuth();
      allow write: if isAdminOrCoord() || canManageAllTeams();
    }

    // ── ACTIVITY LOGS (Books / Service / Registration / Donation) ────────
    match /bookDistributions/{id} {
      allow read:  if isAuth();
      allow write: if isAdminOrCoord() || canManageAllTeams();
    }
    match /services/{id} {
      allow read:  if isAuth();
      allow write: if isAdminOrCoord() || canManageAllTeams();
    }
    match /registrations/{id} {
      allow read:  if isAuth();
      allow write: if isAdminOrCoord() || canManageAllTeams();
    }
    match /donations/{id} {
      allow read:  if isAuth();
      allow write: if isAdminOrCoord() || canManageAllTeams();
    }

    // ── AUDIT TRAILS ─────────────────────────────────────────────────────
    // Anyone can append; only super admin can prune.
    match /profileChanges/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update, delete: if isSuperAdmin();
    }
    match /callingStatusChanges/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update, delete: if isSuperAdmin();
    }

    // ── CONNECT — Personal Meetings ───────────────────────────────────────
    // Authority (PDF): Super admin (all teams) + Coordinator/Facilitator (own team)
    // personalMeetings carries a `teamName` field so we can enforce team scoping.
    match /personalMeetings/{id} {
      allow read:   if isAuth();
      allow create: if isAuth() && (
        isSuperAdmin() || canManageAllTeams()
        || request.resource.data.get('teamName', null) == self().teamName
        || request.resource.data.get('teamName', null) == null
      );
      allow update: if isAuth() && (
        isSuperAdmin() || canManageAllTeams()
        || resource.data.get('teamName', null) == self().teamName
        || resource.data.get('teamName', null) == null
      );
      allow delete: if isSuperAdmin() || canManageAllTeams();
    }

    // ── CONNECT — Interactions (4-level call/meet tracker) ────────────────
    // Authority (PDF): Super admin (all teams) + Coordinator/Facilitator (own team)
    // interactions carries `byUserId` (creator UID) and `teamName`.
    match /interactions/{id} {
      allow read:   if isAuth();
      allow create: if isAuth() && (
        isSuperAdmin() || canManageAllTeams()
        || request.resource.data.get('teamName', null) == self().teamName
        || request.resource.data.get('teamName', null) == null
      );
      allow update: if isSuperAdmin() || canManageAllTeams()
                    || (isAuth() && request.auth.uid == resource.data.byUserId);
      allow delete: if isSuperAdmin();
    }

    // ── SIGN-UP REQUESTS ─────────────────────────────────────────────────
    // Anyone can create a request for their OWN uid (signup + self-heal).
    // Only super admin reads the list and approves.
    match /signupRequests/{id} {
      allow read:   if isSuperAdmin();
      allow create: if isAuth() && request.auth.uid == id;
      allow update: if isSuperAdmin() || (isAuth() && request.auth.uid == id);
      allow delete: if isSuperAdmin();
    }

    // ── USER PROFILES ────────────────────────────────────────────────────
    // read:   anyone signed in (Calling By picker, user management, etc.)
    // create: super admin (approval flow) OR self-create that does NOT grant
    //         superAdmin or canManageAllTeams (self-heal path for stuck signups).
    // update: own uid (safe profile fields only — role/team/flags locked)
    //         OR super admin (anything).
    // delete: super admin only.
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isSuperAdmin()
        || (isAuth() && request.auth.uid == uid
            && request.resource.data.role != 'superAdmin'
            && request.resource.data.get('canManageAllTeams', false) == false);
      allow update: if isSuperAdmin()
        || (isAuth() && request.auth.uid == uid
            && request.resource.data.role          == resource.data.role
            && request.resource.data.teamName      == resource.data.teamName
            && (!('isAttSevaDev'      in request.resource.data) || request.resource.data.isAttSevaDev      == resource.data.isAttSevaDev)
            && (!('canAllTeamCalling' in request.resource.data) || request.resource.data.canAllTeamCalling == resource.data.canAllTeamCalling)
            && (!('canAllTeamReports' in request.resource.data) || request.resource.data.canAllTeamReports == resource.data.canAllTeamReports)
            && (!('canManageAllTeams' in request.resource.data) || request.resource.data.canManageAllTeams == resource.data.canManageAllTeams)
            && (!('status'            in request.resource.data) || request.resource.data.status            == resource.data.status));
      allow delete: if isSuperAdmin();
    }

    // ── APP-WIDE SETTINGS ────────────────────────────────────────────────
    // Calling Mgt tab config (callingWeek date, window toggle, etc.)
    // Authority (PDF): Calling Mgt → Only super admin (read/write/edit)
    match /settings/{docId} {
      allow read:  if isAuth();
      allow write: if isSuperAdmin() || canManageAllTeams();
    }

    // ── CALLING WEEK HISTORY ─────────────────────────────────────────────
    match /callingWeekHistory/{id} {
      allow read:  if isAuth();
      allow write: if isSuperAdmin() || canManageAllTeams();
    }

    // ── DEVOTEE SUPPORT REQUESTS ──────────────────────────────────────────
    // Any authenticated user can submit and read their own requests.
    // Super admin / canManageAllTeams can read all requests and mark resolved.
    match /supportRequests/{id} {
      allow create: if isAuth();
      allow read:   if isAuth() && (
        isSuperAdmin() || canManageAllTeams()
        || resource.data.userId == request.auth.uid
      );
      allow update: if isSuperAdmin() || canManageAllTeams();
      allow delete: if isSuperAdmin();
    }

  }
}
